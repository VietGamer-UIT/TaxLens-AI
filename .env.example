# =============================================================================
# TaxLens-AI — Environment Variable Template
# Copyright: TaxLens-AI by Đoàn Hoàng Việt (Việt Gamer)
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it is in .gitignore).
# =============================================================================

# ── Google Gemini (LLM backend) ───────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── PostgreSQL Audit Database ─────────────────────────────────────────────────
POSTGRES_USER=taxlens
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=taxlens_audit
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Splunk REST API ───────────────────────────────────────────────────────────
# Set SPLUNK_BASE_URL to your Splunk instance URL (including port).
# Leave blank to run in mock mode (dummy SPL results returned).
SPLUNK_BASE_URL=https://splunk.your-org.local:8089
SPLUNK_TOKEN=your_splunk_bearer_token_here

# ── Threat Intelligence APIs ──────────────────────────────────────────────────
# Leave blank to run in mock mode (realistic dummy verdicts returned).
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Host port that FastAPI will be published on (Docker)
BACKEND_PORT=8000
