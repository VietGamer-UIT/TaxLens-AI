# =============================================================================
# ThreatLens-IR — .gitignore
# =============================================================================

# ── Environment & secrets ──────────────────────────────────────────────────────
.env
*.env
*.env.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# ── Pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── Ruff / linting ────────────────────────────────────────────────────────────
.ruff_cache/

# ── Docker ────────────────────────────────────────────────────────────────────
*.log

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Evidence artefacts (never commit forensic images to git) ──────────────────
evidence/
*.raw
*.vmem
*.dmp
*.E01
*.pcap
*.plaso

# ── Alembic generated migration versions (track selectively) ──────────────────
# Uncomment if you want to ignore auto-generated migrations:
# alembic/versions/

# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp